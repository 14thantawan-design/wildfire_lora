PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/wildfire_lora

# Leave SERIAL_PORT empty to run API only without opening the gateway serial port.
# Windows example: COM3
# Linux example: /dev/ttyUSB0
SERIAL_PORT=
SERIAL_BAUD=115200

# Must match GATEWAY_API_KEY in gateway/secrets.h.
GATEWAY_API_KEY=replace-with-a-long-random-key

# Browser origins allowed to call the API directly.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://wildfire.nattaphat.me,https://admin.nattaphat.me

# Optional key for administrative actions coming from another computer.
ADMIN_API_KEY=

# Cloudflare Access-protected administrator hostname and allowed identities.
# Keep the public wildfire hostname out of this list.
ADMIN_HOSTNAME=admin.nattaphat.me
ADMIN_EMAILS=your-cloudflare-login@example.com

GATEWAY_OFFLINE_TIMEOUT_MS=30000

# TEST_MODE default: mark nodes offline if last_seen is older than 60 seconds.
OFFLINE_TIMEOUT_MS=60000
